# ============================================
# Discord Configuration
# ============================================

# Your Discord bot token.
# Get it from:
# https://discord.com/developers/applications
DISCORD_TOKEN=YOUR_DISCORD_BOT_TOKEN

# The Discord server ID where the bot is allowed to operate.
# Enable Developer Mode in Discord, right-click the server, then select "Copy Server ID".
GUILD_ID=YOUR_DISCORD_SERVER_ID

# Only members with this role can use the administrator commands.
# Right-click the role in Discord and select "Copy Role ID".
ROLE_ID=YOUR_ALLOWED_ROLE_ID


# ============================================
# Pterodactyl Panel Configuration
# ============================================

# Your Pterodactyl panel URL.
# Do not include a trailing slash.
# Correct:   https://panel.example.com
# Incorrect: https://panel.example.com/
PTERODACTYL_URL=https://panel.example.com

# A Pterodactyl Application API key with the required read/write permissions.
# Application API keys usually start with "ptla_".
# Do not use a Client API key that starts with "ptlc_".
PTERODACTYL_API_KEY=YOUR_PTERODACTYL_APPLICATION_API_KEY


# ============================================
# Default Server Owner
# ============================================

# The default owner email shown in the server creation form.
# Users can replace this email when submitting the form.
DEFAULT_OWNER_EMAIL=owner@example.com

# Automatically create a non-administrator Pterodactyl account
# when the submitted email does not already exist.
#
# true  = Create the account automatically.
# false = Reject the server creation request if the account does not exist.
AUTO_CREATE_PANEL_USERS=true


# ============================================
# Server Feature Limits
# ============================================

# Maximum number of databases available to each created server.
FEATURE_DATABASES=0

# Maximum number of additional allocations users may manage.
# Increase this value when additional allocation access is required.
FEATURE_ALLOCATIONS=0

# Maximum number of backups available to each created server.
FEATURE_BACKUPS=0


# ============================================
# Server Resource Configuration
# ============================================

# Swap limit in megabytes.
# 0  = Disabled.
# -1 = Unlimited, if supported by your panel configuration.
SERVER_SWAP_MB=0

# Block I/O priority.
# Valid Pterodactyl values are usually between 10 and 1000.
# 500 is the standard default.
SERVER_IO_WEIGHT=500


# ============================================
# HTTP Configuration
# ============================================

# Maximum time, in milliseconds, before a Pterodactyl API request is cancelled.
# 20000 = 20 seconds.
REQUEST_TIMEOUT_MS=20000